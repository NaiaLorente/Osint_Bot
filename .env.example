# Token del bot de Telegram (obtenerlo hablando con @BotFather)
TELEGRAM_TOKEN=pega_aqui_tu_token

# API key de Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxx

# (Opcional) Token de GitHub para subir el rate limit de la API pública
# https://github.com/settings/tokens  -> fine-grained, sin permisos es suficiente
GITHUB_TOKEN=

# (Opcional) Modelo de Claude a usar para Q&A
CLAUDE_MODEL=claude-sonnet-4-5

# (Opcional) Idioma preferido de Wikipedia
WIKIPEDIA_LANG=es

# (Opcional y RECOMENDADO) Lista de IDs de Telegram autorizados, separados por comas.
# Si está vacío, cualquiera que descubra el bot puede usarlo.
# Para saber tu ID, habla con @userinfobot en Telegram.
ALLOWED_USER_IDS=
